{
  "name": "openclaw-sarvam-provider",
  "version": "1.0.0",
  "description": "Sarvam provider for OpenClaw with multiple models, wiki_grounding, and Indian language support",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "openclaw": {
    "extensions": ["./dist/index.js"]
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "test": "vitest",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "openclaw",
    "sarvam",
    "sarvam-provider",
    "language-models",
    "chat-completion",
    "indian-languages",
    "wiki-grounding"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rnagarajanmca/openclaw-sarvam-provider.git"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "prettier": "^3.4.2",
    "eslint": "^9.18.0"
  },
  "files": [
    "dist/**/*",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.16.0"
  }
}